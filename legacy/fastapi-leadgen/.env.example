# ── Gemini (free API) ───────────────────────────────────────────────
# Get a key at https://aistudio.google.com/apikey
# If unset, the app falls back to deterministic logic (no AI).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── SMTP (Phase 2 — real email send) ────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
EMAIL_MAX_PER_HOUR=20

# ── Tracking + CRM (Phase 2/3) ──────────────────────────────────────
# Must be reachable by email clients for open/click tracking
PUBLIC_BASE_URL=http://localhost:8000
CRM_WEBHOOK_URL=

# ── A/B testing ─────────────────────────────────────────────────────
AB_MIN_SENDS=10

# ── Stub modes (no real Meta API calls) ─────────────────────────────
WHATSAPP_STUB_MODE=true
META_STUB_MODE=true


# ── Lead discovery (SerpApi Google Search) ──────────────────────────
# Get a key at https://serpapi.com/
SERPAPI_API_KEY=
SERPAPI_LOG_RAW=true
SERPAPI_RATE_LIMIT_PER_MIN=30
SERPAPI_MAX_PAGES=5
SERPAPI_WEBSITE_TIMEOUT=15
SERPAPI_WEBSITE_CONCURRENCY=5

# ── Scrapers ────────────────────────────────────────────────────────
# false = show the browser window while scraping (great for debugging).
# Set to true on servers / CI where there is no display.
SCRAPER_HEADLESS=false
MAX_RESULTS_PER_TARGET=5

# ── Image generation (Pollinations — free, no key needed) ───────────
# These rarely need changing.
POLLINATIONS_MODEL=flux
POLLINATIONS_WIDTH=1024
POLLINATIONS_HEIGHT=1024
